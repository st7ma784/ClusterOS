#cloud-config

# User setup
users:
  - name: clusteros
    groups: [sudo, adm, docker]
    shell: /bin/bash
    sudo: ALL=(ALL) NOPASSWD:ALL
    # Password enabled for console/SSH access before apply-patch.sh runs.
    # apply-patch.sh locks this and switches to key-only auth after first boot.
    lock_passwd: false
    passwd: "$6$clusteros$5ETidFMrMBCUBW8Rh.tQ1kBp6YI0TtaS3vXI0Ff6gYZmFKO0j6YIQ0yMZCVfPRbCEbm.TGjhlBTzHlLlRRer/"

# Password auth enabled until apply-patch.sh hardens SSH to key-only
ssh_pwauth: true

# Set hostname (overwritten by node-agent setUniqueHostname on first run)
hostname: cluster-node

# Grow root partition to fill disk
growpart:
  mode: auto
  devices: ['/']

resize_rootfs: true

timezone: UTC

# package_upgrade is intentionally false: a full `apt-get upgrade -y` here runs
# BEFORE runcmd (and can take many minutes on first boot), extending the window
# where ssh_pwauth + the default clusteros password are reachable on the LAN.
# apply-patch.sh (last runcmd step) installs/upgrades only what it needs and
# locks the default password — keep this window short.
package_update: true
package_upgrade: false

packages:
  - openssh-server
  - curl
  - wget
  - ca-certificates
  - gnupg
  - jq
  - net-tools
  - iproute2
  # wireguard / wireguard-tools intentionally removed — overlay networking is provided by
  # Tailscale (installed by provision.sh and managed by tailscale-auth / apply-patch.sh).

write_files:
  - path: /etc/sysctl.d/99-clusteros.conf
    content: |
      net.ipv4.ip_forward = 1
      net.ipv6.conf.all.forwarding = 1
      net.bridge.bridge-nf-call-iptables = 1
      net.bridge.bridge-nf-call-ip6tables = 1

  - path: /etc/modules-load.d/clusteros.conf
    content: |
      br_netfilter

  # WiFi: NOT configured via write_files/netplan here. WiFi credentials are
  # written to /etc/clusteros/wifi.env at image-build time (from
  # images/ubuntu/.env's WIFI_SSID / WIFI_KEY — never hardcoded here), but
  # the netplan file itself (80-cluster-wifi.yaml) is written at RUNTIME by
  # cluster-wifi-setup, run by cluster-wifi.service (After=cloud-init.target —
  # i.e. after this cloud-config's stages, not before). networkd requires an
  # exact interface name for `wifis:` entries, which isn't known until
  # cluster-wifi-setup detects the hardware. See
  # images/ubuntu/files/bin/cluster-wifi-setup and
  # images/ubuntu/files/netplan/99-clusteros.yaml.

  # Tailscale first-boot auth script.
  # Reads /etc/clusteros/tailscale.env (written by cluster-make-usb or make deploy).
  # Runs once via runcmd; subsequent boots skip if already connected.
  - path: /usr/local/bin/clusteros-tailscale-init
    permissions: '0755'
    content: |
      #!/bin/bash
      # First-boot Tailscale setup for ClusterOS nodes.
      set -euo pipefail
      log() { echo "[tailscale-init] $*" | tee -a /var/log/clusteros-init.log; }

      TS_ENV="/etc/clusteros/tailscale.env"

      # Install Tailscale if not present
      if ! command -v tailscale >/dev/null 2>&1; then
          log "Installing Tailscale..."
          curl -fsSL https://tailscale.com/install.sh | sh
      fi

      systemctl enable --now tailscaled 2>/dev/null || true
      sleep 3

      # Already connected?
      if tailscale status --json 2>/dev/null | grep -q '"BackendState":"Running"'; then
          log "Tailscale already connected ($(tailscale ip -4 2>/dev/null))"
          exit 0
      fi

      if [[ ! -f "$TS_ENV" ]]; then
          log "No $TS_ENV — skipping auto-auth (run 'sudo tailscale up --authkey=...' manually)"
          exit 0
      fi

      # Source credentials
      TAILSCALE_AUTHKEY=$(grep -v '^#' "$TS_ENV" | grep '^TAILSCALE_AUTHKEY=' | cut -d= -f2- | tr -d ' \r' || true)
      TAILSCALE_OAUTH_CLIENT_ID=$(grep -v '^#' "$TS_ENV" | grep '^TAILSCALE_OAUTH_CLIENT_ID=' | cut -d= -f2- | tr -d ' \r' || true)
      TAILSCALE_OAUTH_CLIENT_SECRET=$(grep -v '^#' "$TS_ENV" | grep '^TAILSCALE_OAUTH_CLIENT_SECRET=' | cut -d= -f2- | tr -d ' \r' || true)

      AUTH_KEY=""

      # OAuth path: generate a fresh single-use key (preferred — no expiry on the credentials)
      if [[ -n "${TAILSCALE_OAUTH_CLIENT_ID:-}" && -n "${TAILSCALE_OAUTH_CLIENT_SECRET:-}" ]]; then
          log "Requesting Tailscale auth key via OAuth..."
          TOKEN=$(curl -fsSL --connect-timeout 10 -X POST https://api.tailscale.com/api/v2/oauth/token \
              -d "client_id=${TAILSCALE_OAUTH_CLIENT_ID}&client_secret=${TAILSCALE_OAUTH_CLIENT_SECRET}" \
              | jq -r '.access_token // empty')
          if [[ -n "$TOKEN" ]]; then
              AUTH_KEY=$(curl -fsSL --connect-timeout 10 -X POST https://api.tailscale.com/api/v2/tailnet/-/keys \
                  -H "Authorization: Bearer $TOKEN" \
                  -H "Content-Type: application/json" \
                  -d '{"capabilities":{"devices":{"create":{"reusable":false,"ephemeral":false,"preauthorized":true}}},"expirySeconds":300}' \
                  | jq -r '.key // empty')
              [[ -n "$AUTH_KEY" ]] && log "OAuth auth key obtained"
          fi
      fi

      # Pre-configured key fallback
      if [[ -z "$AUTH_KEY" && -n "${TAILSCALE_AUTHKEY:-}" ]]; then
          AUTH_KEY="$TAILSCALE_AUTHKEY"
          log "Using pre-configured auth key"
      fi

      if [[ -z "$AUTH_KEY" ]]; then
          log "No valid Tailscale credentials in $TS_ENV — manual auth required"
          exit 1
      fi

      log "Authenticating with Tailscale..."
      tailscale up --authkey="$AUTH_KEY" --accept-routes --accept-dns=false --reset
      sleep 3
      log "Connected: $(tailscale ip -4 2>/dev/null || echo pending)"

runcmd:
  # NOTE: deliberately no `netplan apply` here.
  #   - Ethernet (images/ubuntu/files/netplan/99-clusteros.yaml) is already
  #     applied by netplan's early-boot generator, well before cloud-init
  #     itself starts (cloud-init needs network for package_update).
  #   - WiFi (80-cluster-wifi.yaml) doesn't exist yet at this point — it's
  #     written at runtime by cluster-wifi-setup (cluster-wifi.service).
  #   - cluster-wifi.service has no ordering relative to cloud-final.service
  #     (both only depend on cloud-init.target — see
  #     wifi-rfkill-unblock.service's comment), so it can be concurrently
  #     mid-DHCP-wait for the wifi interface right now. A `netplan apply`
  #     here would pick up its just-written 80-cluster-wifi.yaml and trigger
  #     a second networkd reload for that interface, bouncing the link and
  #     interrupting its DHCP negotiation.
  - sysctl --system
  - systemctl enable ssh
  - systemctl start ssh
  # Tailscale: install and auth using credentials from the patch bundle.
  # The patch bundle (written by cluster-make-usb) places tailscale.env before
  # this runs; if no bundle is present, the script exits cleanly.
  - |
    if [ -f /root/patch/tailscale.env ]; then
      mkdir -p /etc/clusteros
      cp /root/patch/tailscale.env /etc/clusteros/tailscale.env
      chmod 600 /etc/clusteros/tailscale.env
    fi
  - /usr/local/bin/clusteros-tailscale-init || true
  # Apply the cluster patch bundle if present (placed there by cluster-make-usb).
  # This installs node-agent, joins the cluster, and sets up all services.
  #
  # Guarded by .bootstrapped — same check used by node-agent.service's
  # ExecStartPre (images/ubuntu/files/systemd/node-agent.service). On first
  # boot, node-agent.service starts as soon as network-online+tailscaled+
  # cluster-wifi are up, usually well before cloud-init's runcmd reaches this
  # step, and its ExecStartPre already runs apply-patch.sh — writing
  # .bootstrapped partway through (step 9/10) and scheduling a reboot
  # (step 10/10). Without this guard, runcmd would ALSO run apply-patch.sh,
  # unconditionally and concurrently: two simultaneous apt-get/dpkg
  # operations, iptables flushes, and netplan rewrites, with the script's
  # `set -e` aborting whichever loses the dpkg lock mid-patch — leaving the
  # node half-patched (node-agent killed, state wiped) with .bootstrapped
  # never written.
  - |
    if [ -f /root/patch/apply-patch.sh ] && [ ! -f /var/lib/clusteros/.bootstrapped ]; then
      bash /root/patch/apply-patch.sh >> /var/log/clusteros-join.log 2>&1 && mkdir -p /var/lib/clusteros && touch /var/lib/clusteros/.bootstrapped
    fi

final_message: "ClusterOS cloud-init complete after $UPTIME seconds"
