# Copy this file to images/ubuntu/.env and fill in your Tailscale credentials.
# .env is gitignored (contains secrets). .env.example is tracked.
#
# Get OAuth credentials from: https://login.tailscale.com/admin/settings/oauth
TAILSCALE_OAUTH_CLIENT_ID=
TAILSCALE_OAUTH_CLIENT_SECRET=
# Or use a pre-auth key instead:
TAILSCALE_AUTHKEY=
TAILSCALE_TAGS=clusteros

# GitHub Actions self-hosted runners (org-scoped, scales to zero when idle)
# Create a PAT at https://github.com/settings/tokens with admin:org scope.
# Leave empty to skip runner deployment.
GITHUB_ORG=
GITHUB_PAT=
