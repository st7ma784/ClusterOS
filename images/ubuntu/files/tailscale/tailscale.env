# Tailscale Configuration for ClusterOS
# Replace these placeholder values with real credentials from https://login.tailscale.com
#
# SETUP STEPS:
# 1. Create an OAuth client at https://login.tailscale.com/admin/settings/oauth
# 2. If using tags (recommended), first define them in your ACL policy:
#    Go to https://login.tailscale.com/admin/acls and add to the policy:
#      "tagOwners": {
#        "tag:clusteros": ["autogroup:admin"]
#      }
# 3. When creating the OAuth client, grant it the "tag:clusteros" scope
#    (under "Devices" > "Write" permissions with tag:clusteros)
# 4. Paste the client ID and secret below

# OAuth Client credentials (recommended - never expire)
TAILSCALE_OAUTH_CLIENT_ID=kt8gqDjUYX11CNTRL
TAILSCALE_OAUTH_CLIENT_SECRET=tskey-client-kt8gqDjUYX11CNTRL-PdG7MBdt774Sfet5Aqax64QLpXJ8vWFWW

# Tailscale Tags - MUST be defined in your ACL policy before use (see above)
# If not defined, auth will retry without tags but the device won't be tagged
TAILSCALE_TAGS=clusteros

# Auth Key (alternative/fallback method - leave empty when using OAuth)
# Get this from: https://login.tailscale.com/admin/settings/keys  
# TAILSCALE_AUTHKEY=

# Optional: Custom hostname
TAILSCALE_HOSTNAME=cluster-node
