#!/bin/bash
# ClusterOS Install - Install ClusterOS to a target disk
# Usage: cluster-os-install

set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

echo -e "${CYAN}"
cat << 'EOF'
   _____ _           _              ___  ____  
  / ____| |         | |            / _ \/ ___| 
 | |    | |_   _ ___| |_ ___ _ __ | | | \___ \ 
 | |    | | | | / __| __/ _ \ '__|| | | |___) |
 | |____| | |_| \__ \ ||  __/ |   | |_| |____/ 
  \_____|_|\__,_|___/\__\___|_|    \___/|_____|
                                                
         Hardware Installation Tool
EOF
echo -e "${NC}"
echo ""

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Error: This script must be run as root${NC}"
    echo "Usage: sudo cluster-os-install"
    exit 1
fi

# Check if system is booted in UEFI mode
if [ ! -d /sys/firmware/efi ]; then
    echo -e "${RED}Error: System is not booted in UEFI mode${NC}"
    echo ""
    echo "ClusterOS requires UEFI boot. Please:"
    echo "  1. Reboot and enter BIOS/UEFI settings"
    echo "  2. Enable UEFI boot mode (disable Legacy/CSM)"
    echo "  3. Boot the USB drive again in UEFI mode"
    echo ""
    exit 1
fi

# Detect boot device (the USB/disk we're booted from)
BOOT_DEV=""
ROOT_MOUNT=$(findmnt -n -o SOURCE /)
if [ -n "$ROOT_MOUNT" ]; then
    # Get the base device (remove partition number)
    BOOT_DEV=$(lsblk -n -o PKNAME "$ROOT_MOUNT" 2>/dev/null | head -1)
    if [ -n "$BOOT_DEV" ]; then
        BOOT_DEV="/dev/$BOOT_DEV"
    fi
fi

echo -e "${YELLOW}Scanning for available disks...${NC}"
echo ""

# Build array of available target devices
declare -a DEVICES
declare -a DEVICE_INFO
idx=0

for dev in /dev/sd? /dev/nvme?n? /dev/vd? /dev/xvd?; do
    if [ -b "$dev" ] 2>/dev/null; then
        # Skip the boot device
        if [ "$dev" = "$BOOT_DEV" ]; then
            continue
        fi
        
        # Skip devices smaller than 8GB
        size_bytes=$(lsblk -b -d -n -o SIZE "$dev" 2>/dev/null || echo "0")
        if [ "$size_bytes" -lt 8000000000 ]; then
            continue
        fi
        
        size=$(lsblk -d -n -o SIZE "$dev" 2>/dev/null || echo "??")
        model=$(lsblk -d -n -o MODEL "$dev" 2>/dev/null | xargs || echo "Unknown")
        tran=$(lsblk -d -n -o TRAN "$dev" 2>/dev/null || echo "")
        
        DEVICES[$idx]="$dev"
        DEVICE_INFO[$idx]="$size  $model [$tran]"
        idx=$((idx + 1))
    fi
done 2>/dev/null

# Check if we found any devices
if [ ${#DEVICES[@]} -eq 0 ]; then
    echo -e "${RED}No suitable target devices found!${NC}"
    echo ""
    echo "Current disk layout:"
    lsblk -d -o NAME,SIZE,MODEL,TRAN | grep -v "loop\|sr\|rom"
    echo ""
    echo "Boot device: $BOOT_DEV (excluded)"
    exit 1
fi

# Show boot device info
echo -e "${CYAN}Boot device (excluded):${NC}"
boot_size=$(lsblk -d -n -o SIZE "$BOOT_DEV" 2>/dev/null || echo "??")
boot_model=$(lsblk -d -n -o MODEL "$BOOT_DEV" 2>/dev/null | xargs || echo "")
echo "  $BOOT_DEV - $boot_size $boot_model"
echo ""

# Display available devices with numbers
echo -e "${YELLOW}Available target devices:${NC}"
echo ""
for i in "${!DEVICES[@]}"; do
    num=$((i + 1))
    echo -e "  ${GREEN}[$num]${NC} ${DEVICES[$i]} - ${DEVICE_INFO[$i]}"
done
echo ""
echo -e "  ${RED}[0]${NC} Cancel installation"
echo ""

# Get user selection
while true; do
    read -p "Select target device [0-${#DEVICES[@]}]: " selection
    
    # Validate input
    if [[ "$selection" =~ ^[0-9]+$ ]]; then
        if [ "$selection" -eq 0 ]; then
            echo "Installation cancelled."
            exit 0
        elif [ "$selection" -ge 1 ] && [ "$selection" -le ${#DEVICES[@]} ]; then
            TARGET_DEV="${DEVICES[$((selection - 1))]}"
            break
        fi
    fi
    echo -e "${RED}Invalid selection. Please enter a number between 0 and ${#DEVICES[@]}${NC}"
done

# Get device info for confirmation
TARGET_SIZE=$(lsblk -d -n -o SIZE "$TARGET_DEV" 2>/dev/null || echo "unknown")
TARGET_MODEL=$(lsblk -d -n -o MODEL "$TARGET_DEV" 2>/dev/null | xargs || echo "")

echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo -e "${YELLOW}                    INSTALLATION SUMMARY${NC}"
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Target Device:  ${CYAN}$TARGET_DEV${NC}"
echo -e "  Size:           $TARGET_SIZE"
echo -e "  Model:          $TARGET_MODEL"
echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "${RED}${BOLD}  ⚠️  WARNING: ALL DATA ON $TARGET_DEV WILL BE ERASED!${NC}"
echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo ""

# Require explicit confirmation
read -p "Type 'YES' (uppercase) to confirm installation: " confirm

if [ "$confirm" != "YES" ]; then
    echo ""
    echo "Installation cancelled."
    exit 0
fi

echo ""
echo -e "${CYAN}Starting ClusterOS installation to $TARGET_DEV...${NC}"
echo ""

# Unmount any existing partitions on target
echo "[1/6] Unmounting existing partitions..."
for part in "${TARGET_DEV}"*; do
    if [ -b "$part" ] && [ "$part" != "$TARGET_DEV" ]; then
        umount "$part" 2>/dev/null || true
    fi
done

# Wipe existing partition table
echo "[2/6] Creating partition table..."
wipefs -a "$TARGET_DEV" 2>/dev/null || true
sgdisk --zap-all "$TARGET_DEV" 2>/dev/null || true

# Create GPT partition table with EFI and root partitions
# Partition 1: EFI System Partition (512MB)
# Partition 2: Root filesystem (rest of disk)
sgdisk -n 1:0:+512M -t 1:ef00 -c 1:"EFI" "$TARGET_DEV"
sgdisk -n 2:0:0 -t 2:8300 -c 2:"ClusterOS" "$TARGET_DEV"

# Set boot/esp attribute on EFI partition (required by some UEFI firmware)
# Attribute 0 = system partition, Attribute 2 = legacy BIOS bootable
sgdisk -A 1:set:0 "$TARGET_DEV"
sgdisk -A 1:set:2 "$TARGET_DEV"

# Wait for kernel to recognize new partitions
sleep 2
partprobe "$TARGET_DEV" 2>/dev/null || true
sleep 1

# Determine partition names
if [[ "$TARGET_DEV" == *"nvme"* ]] || [[ "$TARGET_DEV" == *"loop"* ]]; then
    EFI_PART="${TARGET_DEV}p1"
    ROOT_PART="${TARGET_DEV}p2"
else
    EFI_PART="${TARGET_DEV}1"
    ROOT_PART="${TARGET_DEV}2"
fi

# Wait for partitions to appear
echo "    Waiting for partitions..."
for i in {1..10}; do
    if [ -b "$EFI_PART" ] && [ -b "$ROOT_PART" ]; then
        break
    fi
    sleep 1
done

if [ ! -b "$EFI_PART" ] || [ ! -b "$ROOT_PART" ]; then
    echo -e "${RED}Error: Partitions did not appear${NC}"
    exit 1
fi

# Format partitions
echo "[3/6] Formatting partitions..."
mkfs.vfat -F32 -n "CLUSTEREFI" "$EFI_PART"
mkfs.ext4 -L "ClusterOS" -F "$ROOT_PART"

# Mount partitions
echo "[4/6] Copying system files..."
MOUNT_DIR="/mnt/clusteros-install"
mkdir -p "$MOUNT_DIR"
mount "$ROOT_PART" "$MOUNT_DIR"
mkdir -p "$MOUNT_DIR/boot/efi"
mount "$EFI_PART" "$MOUNT_DIR/boot/efi"

# Copy root filesystem (excluding special filesystems)
echo "    Copying root filesystem (this may take several minutes)..."
rsync -aAXH --info=progress2 \
    --exclude='/dev/*' \
    --exclude='/proc/*' \
    --exclude='/sys/*' \
    --exclude='/tmp/*' \
    --exclude='/run/*' \
    --exclude='/mnt/*' \
    --exclude='/media/*' \
    --exclude='/lost+found' \
    --exclude='/var/log/*' \
    --exclude='/var/cache/apt/archives/*.deb' \
    --exclude='/boot/efi/*' \
    --exclude='/boot/grub/*' \
    --exclude='/var/lib/tailscale/tailscaled.state' \
    / "$MOUNT_DIR/"

# Create necessary directories
mkdir -p "$MOUNT_DIR"/{dev,proc,sys,tmp,run,mnt,media}
chmod 1777 "$MOUNT_DIR/tmp"

# Ensure cluster credentials are copied (they're critical for cluster membership)
echo "    Ensuring cluster credentials are in place..."
if [ -f /etc/clusteros/cluster.key ]; then
    mkdir -p "$MOUNT_DIR/etc/clusteros"
    cp /etc/clusteros/cluster.key "$MOUNT_DIR/etc/clusteros/"
    chmod 600 "$MOUNT_DIR/etc/clusteros/cluster.key"
    echo "      Cluster key copied"
fi
if [ -f /etc/clusteros/serf.key ]; then
    cp /etc/clusteros/serf.key "$MOUNT_DIR/etc/clusteros/"
    chmod 600 "$MOUNT_DIR/etc/clusteros/serf.key"
    echo "      Serf key copied"
fi
if [ -f /etc/clusteros/tailscale.env ]; then
    cp /etc/clusteros/tailscale.env "$MOUNT_DIR/etc/clusteros/"
    chmod 600 "$MOUNT_DIR/etc/clusteros/tailscale.env"
    echo "      Tailscale credentials copied"
fi
if [ -f /etc/clusteros/node.yaml ]; then
    cp /etc/clusteros/node.yaml "$MOUNT_DIR/etc/clusteros/"
    chmod 644 "$MOUNT_DIR/etc/clusteros/node.yaml"
    echo "      Node config copied"
fi

# Clear Tailscale state so new install gets fresh identity
rm -rf "$MOUNT_DIR/var/lib/tailscale/tailscaled.state" 2>/dev/null || true

# Generate new node identity for the installed system
rm -f "$MOUNT_DIR/var/lib/cluster-os/identity.json" 2>/dev/null || true
rm -f "$MOUNT_DIR/var/lib/clusteros/identity.json" 2>/dev/null || true
echo "    New node will generate fresh identity on first boot"

# Remove any GRUB remnants that got copied
echo "    Removing GRUB bootloader..."
rm -rf "$MOUNT_DIR/boot/grub" 2>/dev/null || true
rm -rf "$MOUNT_DIR/etc/grub.d" 2>/dev/null || true
rm -f "$MOUNT_DIR/etc/default/grub" 2>/dev/null || true

# Update fstab for new disk
echo "[5/6] Configuring boot..."
ROOT_UUID=$(blkid -s UUID -o value "$ROOT_PART")
EFI_UUID=$(blkid -s UUID -o value "$EFI_PART")

cat > "$MOUNT_DIR/etc/fstab" <<FSTAB
# ClusterOS filesystem table
# <device>                                <mount>     <type>  <options>       <dump> <pass>
UUID=$ROOT_UUID    /           ext4    defaults,noatime    0      1
UUID=$EFI_UUID     /boot/efi   vfat    umask=0077          0      1
FSTAB

# Install systemd-boot (EFI boot manager - simpler than GRUB)
echo "    Installing systemd-boot..."

# Bind mount for chroot
mount --bind /dev "$MOUNT_DIR/dev"
mount --bind /dev/pts "$MOUNT_DIR/dev/pts"
mount --bind /proc "$MOUNT_DIR/proc"
mount --bind /sys "$MOUNT_DIR/sys"
if [ -d /sys/firmware/efi/efivars ]; then
    mount --bind /sys/firmware/efi/efivars "$MOUNT_DIR/sys/firmware/efi/efivars" || {
        echo -e "${YELLOW}Warning: Could not mount efivars - efibootmgr may not work${NC}"
    }
else
    echo -e "${RED}Error: /sys/firmware/efi/efivars not found - not in UEFI mode?${NC}"
    exit 1
fi

# Install systemd-boot in chroot
# Use double-quoted heredoc so ROOT_UUID gets expanded from parent script
chroot "$MOUNT_DIR" /bin/bash <<CHROOT_SCRIPT
set -e

# ROOT_UUID expanded from parent script during heredoc creation
ROOT_UUID="$ROOT_UUID"

if [ -z "\$ROOT_UUID" ]; then
    echo "Error: ROOT_UUID is empty"
    exit 1
fi

echo "    Using ROOT_UUID: \$ROOT_UUID"

# Remove GRUB packages to prevent conflicts
echo "    Removing GRUB packages..."
apt-get remove -y --purge grub-common grub-pc grub-pc-bin grub-efi-amd64 grub-efi-amd64-bin grub2-common grub-efi-amd64-signed shim-signed 2>/dev/null || true
apt-get autoremove -y 2>/dev/null || true

# Aggressively clean out any GRUB EFI files
echo "    Cleaning GRUB EFI files..."
rm -rf /boot/efi/EFI/ubuntu 2>/dev/null || true
rm -rf /boot/efi/EFI/debian 2>/dev/null || true
rm -rf /boot/efi/EFI/BOOT/grub* 2>/dev/null || true
rm -rf /boot/efi/EFI/BOOT/GRUB* 2>/dev/null || true
rm -f /boot/efi/EFI/BOOT/shimx64.efi 2>/dev/null || true
rm -f /boot/efi/EFI/BOOT/mmx64.efi 2>/dev/null || true
rm -rf /boot/grub 2>/dev/null || true
rm -rf /etc/grub.d 2>/dev/null || true
rm -f /etc/default/grub 2>/dev/null || true

# Install systemd-boot to EFI partition
echo "    Installing systemd-boot..."
mkdir -p /boot/efi/EFI/systemd /boot/efi/EFI/BOOT

bootctl install --esp-path=/boot/efi 2>/dev/null || bootctl install --path=/boot/efi 2>/dev/null || {
    # Manual fallback installation
    echo "    Using manual systemd-boot installation..."
    if [ -f /usr/lib/systemd/boot/efi/systemd-bootx64.efi ]; then
        cp /usr/lib/systemd/boot/efi/systemd-bootx64.efi /boot/efi/EFI/systemd/
        cp /usr/lib/systemd/boot/efi/systemd-bootx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
    else
        echo "ERROR: systemd-bootx64.efi not found!"
        ls -la /usr/lib/systemd/boot/efi/ 2>/dev/null || echo "Directory does not exist"
        exit 1
    fi
}

# CRITICAL: Always ensure fallback bootloader exists (some UEFI only looks here)
if [ ! -f /boot/efi/EFI/BOOT/BOOTX64.EFI ]; then
    echo "    Creating fallback BOOTX64.EFI..."
    if [ -f /boot/efi/EFI/systemd/systemd-bootx64.efi ]; then
        cp /boot/efi/EFI/systemd/systemd-bootx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
    elif [ -f /usr/lib/systemd/boot/efi/systemd-bootx64.efi ]; then
        cp /usr/lib/systemd/boot/efi/systemd-bootx64.efi /boot/efi/EFI/BOOT/BOOTX64.EFI
    fi
fi

# Verify bootloader is in place
if [ ! -f /boot/efi/EFI/BOOT/BOOTX64.EFI ]; then
    echo "ERROR: Failed to install BOOTX64.EFI fallback bootloader!"
    exit 1
fi
echo "    BOOTX64.EFI installed successfully"

# Create loader configuration
mkdir -p /boot/efi/loader/entries

cat > /boot/efi/loader/loader.conf <<LOADER
default clusteros.conf
timeout 0
console-mode max
editor no
LOADER

# Find the kernel and initrd
KERNEL=\$(ls /boot/vmlinuz-* 2>/dev/null | sort -V | tail -1)
INITRD=\$(ls /boot/initrd.img-* 2>/dev/null | sort -V | tail -1)

if [ -z "\$KERNEL" ] || [ -z "\$INITRD" ]; then
    echo "Error: Kernel or initrd not found"
    ls -la /boot/
    exit 1
fi

echo "    Found kernel: \$KERNEL"
echo "    Found initrd: \$INITRD"

KERNEL_VERSION=\$(basename "\$KERNEL" | sed 's/vmlinuz-//')

# Copy kernel and initrd to EFI partition
cp "\$KERNEL" /boot/efi/vmlinuz
cp "\$INITRD" /boot/efi/initrd.img

echo "    Kernel and initrd copied to EFI partition"

# Create boot entry (ROOT_UUID was set at top of chroot script)
cat > /boot/efi/loader/entries/clusteros.conf <<INNERENTRY
title   ClusterOS
linux   /vmlinuz
initrd  /initrd.img
options root=UUID=\$ROOT_UUID rw quiet splash
INNERENTRY

# Create fallback entry
cat > /boot/efi/loader/entries/clusteros-recovery.conf <<INNERENTRY
title   ClusterOS (Recovery)
linux   /vmlinuz
initrd  /initrd.img
options root=UUID=\$ROOT_UUID rw single
INNERENTRY

echo "    Boot entries created:"
cat /boot/efi/loader/entries/clusteros.conf

# Verify the EFI partition structure
echo ""
echo "    EFI partition structure:"
find /boot/efi -type f 2>/dev/null | head -20

echo ""
echo "systemd-boot installed successfully"
CHROOT_SCRIPT

# Unmount bind mounts
umount "$MOUNT_DIR/sys/firmware/efi/efivars" 2>/dev/null || true
umount "$MOUNT_DIR/sys"
umount "$MOUNT_DIR/proc"
umount "$MOUNT_DIR/dev/pts"
umount "$MOUNT_DIR/dev"

# Set boot order via efibootmgr if available
if command -v efibootmgr &>/dev/null; then
    echo "    Configuring EFI boot order..."
    
    # Get disk and partition number for EFI
    DISK_FOR_EFI="$TARGET_DEV"
    PART_NUM=1
    
    # Only remove existing ClusterOS entries to avoid duplicates
    # DO NOT delete other boot entries (ubuntu, grub, etc.) - this breaks USB reuse!
    for bootnum in $(efibootmgr 2>/dev/null | grep -i "clusteros" | awk '{print $1}' | sed 's/Boot//;s/\*//'); do
        echo "    Removing duplicate ClusterOS entry: Boot$bootnum"
        efibootmgr --delete-bootnum --bootnum "$bootnum" 2>/dev/null || true
    done
    
    # Ensure fallback bootloader directory and file exist
    mkdir -p "$MOUNT_DIR/boot/efi/EFI/BOOT"
    mkdir -p "$MOUNT_DIR/boot/efi/EFI/systemd"
    
    # Copy systemd-boot to fallback location (BOOTX64.EFI is what EFI loads by default)
    if [ -f "$MOUNT_DIR/boot/efi/EFI/systemd/systemd-bootx64.efi" ]; then
        cp "$MOUNT_DIR/boot/efi/EFI/systemd/systemd-bootx64.efi" \
           "$MOUNT_DIR/boot/efi/EFI/BOOT/BOOTX64.EFI"
    elif [ -f "$MOUNT_DIR/usr/lib/systemd/boot/efi/systemd-bootx64.efi" ]; then
        cp "$MOUNT_DIR/usr/lib/systemd/boot/efi/systemd-bootx64.efi" \
           "$MOUNT_DIR/boot/efi/EFI/BOOT/BOOTX64.EFI"
        cp "$MOUNT_DIR/usr/lib/systemd/boot/efi/systemd-bootx64.efi" \
           "$MOUNT_DIR/boot/efi/EFI/systemd/systemd-bootx64.efi"
    fi
    
    # Remove any GRUB files that might have been copied
    rm -rf "$MOUNT_DIR/boot/efi/EFI/ubuntu" 2>/dev/null || true
    rm -rf "$MOUNT_DIR/boot/efi/EFI/debian" 2>/dev/null || true
    rm -f "$MOUNT_DIR/boot/efi/EFI/BOOT/grub"* 2>/dev/null || true
    rm -f "$MOUNT_DIR/boot/efi/EFI/BOOT/GRUB"* 2>/dev/null || true
    
    # Create EFI boot entry for systemd-boot
    efibootmgr --create --disk "$DISK_FOR_EFI" --part "$PART_NUM" \
        --label "ClusterOS" --loader '\EFI\systemd\systemd-bootx64.efi' 2>/dev/null || \
    efibootmgr --create --disk "$DISK_FOR_EFI" --part "$PART_NUM" \
        --label "ClusterOS" --loader '\EFI\BOOT\BOOTX64.EFI' 2>/dev/null || true
    
    # Get the boot number of our new entry and set it as first in order
    CLUSTEROS_BOOTNUM=$(efibootmgr 2>/dev/null | grep -i "ClusterOS" | head -1 | awk '{print $1}' | sed 's/Boot//;s/\*//')
    if [ -n "$CLUSTEROS_BOOTNUM" ]; then
        CURRENT_ORDER=$(efibootmgr 2>/dev/null | grep "BootOrder" | awk '{print $2}')
        if [ -n "$CURRENT_ORDER" ]; then
            # Put ClusterOS first, remove it from current position if present
            NEW_ORDER=$(echo "$CURRENT_ORDER" | sed "s/$CLUSTEROS_BOOTNUM,//g;s/,$CLUSTEROS_BOOTNUM//g;s/$CLUSTEROS_BOOTNUM//g")
            if [ -n "$NEW_ORDER" ]; then
                NEW_ORDER="$CLUSTEROS_BOOTNUM,$NEW_ORDER"
            else
                NEW_ORDER="$CLUSTEROS_BOOTNUM"
            fi
            efibootmgr --bootorder "$NEW_ORDER" 2>/dev/null || true
        else
            efibootmgr --bootorder "$CLUSTEROS_BOOTNUM" 2>/dev/null || true
        fi
        echo "    ClusterOS set as first boot option"
    fi
    
    # Show final boot configuration
    echo "    EFI boot configuration:"
    efibootmgr 2>/dev/null | head -20 | sed 's/^/      /'
fi

echo "[6/6] Finalizing installation..."

# Sync and unmount
sync
umount "$MOUNT_DIR/boot/efi"
umount "$MOUNT_DIR"
rmdir "$MOUNT_DIR" 2>/dev/null || true

echo ""
echo -e "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}           ✓ ClusterOS Installation Complete!${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
echo ""
echo "  Installed to: $TARGET_DEV"
echo "  Boot method:  UEFI (systemd-boot)"
echo ""
echo -e "${YELLOW}Next steps:${NC}"
echo "  1. Remove the USB drive"
echo "  2. Reboot: ${CYAN}sudo reboot${NC}"
echo "  3. System will boot ClusterOS from $TARGET_DEV"
echo ""
echo "  After reboot:"
echo "    • Run ${GREEN}cluster-init${NC} to start a new cluster"
echo "    • Or ${GREEN}cluster-join <ip>${NC} to join existing cluster"
echo ""
