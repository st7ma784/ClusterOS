#!/bin/bash
# ClusterOS - Create USB Installer
# Write the embedded installer image to a USB drive
# Usage: cluster-os-create-usb

set -e

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

INSTALLER_IMAGE="/usr/share/clusteros/installer.img.gz"

echo -e "${CYAN}"
cat << 'EOF'
   _____ _           _              ___  ____  
  / ____| |         | |            / _ \/ ___| 
 | |    | |_   _ ___| |_ ___ _ __ | | | \___ \ 
 | |    | | | | / __| __/ _ \ '__|| | | |___) |
 | |____| | |_| \__ \ ||  __/ |   | |_| |____/ 
  \_____|_|\__,_|___/\__\___|_|    \___/|_____|
                                                
         USB Installer Creator
EOF
echo -e "${NC}"
echo ""

# Check if running as root
if [ "$EUID" -ne 0 ]; then
    echo -e "${RED}Error: This script must be run as root${NC}"
    echo "Usage: sudo cluster-os-create-usb"
    exit 1
fi

# Check if installer image exists
if [ ! -f "$INSTALLER_IMAGE" ]; then
    echo -e "${RED}Error: Installer image not found at $INSTALLER_IMAGE${NC}"
    echo ""
    echo "This system may not have the embedded installer."
    echo "You can download the installer from the ClusterOS releases."
    exit 1
fi

# Get installer size
INSTALLER_SIZE=$(du -h "$INSTALLER_IMAGE" | cut -f1)
echo -e "Embedded installer: ${GREEN}$INSTALLER_IMAGE${NC} ($INSTALLER_SIZE compressed)"
echo ""

# Detect boot device to exclude
BOOT_DEV=""
ROOT_MOUNT=$(findmnt -n -o SOURCE /)
if [ -n "$ROOT_MOUNT" ]; then
    BOOT_DEV=$(lsblk -n -o PKNAME "$ROOT_MOUNT" 2>/dev/null | head -1)
    if [ -n "$BOOT_DEV" ]; then
        BOOT_DEV="/dev/$BOOT_DEV"
    fi
fi

echo -e "${YELLOW}Scanning for USB drives...${NC}"
echo ""

# Build array of available USB devices
declare -a DEVICES
declare -a DEVICE_INFO
idx=0

for dev in /dev/sd? /dev/nvme?n?; do
    if [ -b "$dev" ] 2>/dev/null; then
        # Skip the boot device
        if [ "$dev" = "$BOOT_DEV" ]; then
            continue
        fi
        
        # Check if it's a removable device (USB) or small enough to be USB
        removable=$(cat "/sys/block/$(basename $dev)/removable" 2>/dev/null || echo "0")
        tran=$(lsblk -d -n -o TRAN "$dev" 2>/dev/null || echo "")
        size_bytes=$(lsblk -b -d -n -o SIZE "$dev" 2>/dev/null || echo "0")
        
        # Include if removable OR USB transport OR size < 256GB (likely USB)
        if [ "$removable" = "1" ] || [ "$tran" = "usb" ] || [ "$size_bytes" -lt 274877906944 ]; then
            size=$(lsblk -d -n -o SIZE "$dev" 2>/dev/null || echo "??")
            model=$(lsblk -d -n -o MODEL "$dev" 2>/dev/null | xargs || echo "Unknown")
            
            DEVICES[$idx]="$dev"
            DEVICE_INFO[$idx]="$size  $model [$tran]"
            idx=$((idx + 1))
        fi
    fi
done 2>/dev/null

# Check if we found any devices
if [ ${#DEVICES[@]} -eq 0 ]; then
    echo -e "${RED}No USB drives found!${NC}"
    echo ""
    echo "Please insert a USB drive and try again."
    echo ""
    echo "Current disk layout:"
    lsblk -d -o NAME,SIZE,MODEL,TRAN,RM | grep -v "loop\|sr\|rom"
    exit 1
fi

# Show boot device info
if [ -n "$BOOT_DEV" ]; then
    echo -e "${CYAN}System disk (excluded):${NC}"
    boot_size=$(lsblk -d -n -o SIZE "$BOOT_DEV" 2>/dev/null || echo "??")
    boot_model=$(lsblk -d -n -o MODEL "$BOOT_DEV" 2>/dev/null | xargs || echo "")
    echo "  $BOOT_DEV - $boot_size $boot_model"
    echo ""
fi

# Display available devices with numbers
echo -e "${YELLOW}Available USB drives:${NC}"
echo ""
for i in "${!DEVICES[@]}"; do
    num=$((i + 1))
    echo -e "  ${GREEN}[$num]${NC} ${DEVICES[$i]} - ${DEVICE_INFO[$i]}"
done
echo ""
echo -e "  ${RED}[0]${NC} Cancel"
echo ""

# Get user selection
while true; do
    read -p "Select USB drive [0-${#DEVICES[@]}]: " selection
    
    if [[ "$selection" =~ ^[0-9]+$ ]]; then
        if [ "$selection" -eq 0 ]; then
            echo "Cancelled."
            exit 0
        elif [ "$selection" -ge 1 ] && [ "$selection" -le ${#DEVICES[@]} ]; then
            TARGET_DEV="${DEVICES[$((selection - 1))]}"
            break
        fi
    fi
    echo -e "${RED}Invalid selection. Please enter a number between 0 and ${#DEVICES[@]}${NC}"
done

# Get device info for confirmation
TARGET_SIZE=$(lsblk -d -n -o SIZE "$TARGET_DEV" 2>/dev/null || echo "unknown")
TARGET_MODEL=$(lsblk -d -n -o MODEL "$TARGET_DEV" 2>/dev/null | xargs || echo "")

echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo -e "${YELLOW}                    USB CREATION SUMMARY${NC}"
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "  Target USB:     ${CYAN}$TARGET_DEV${NC}"
echo -e "  Size:           $TARGET_SIZE"
echo -e "  Model:          $TARGET_MODEL"
echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo ""
echo -e "${RED}${BOLD}  ⚠️  WARNING: ALL DATA ON $TARGET_DEV WILL BE ERASED!${NC}"
echo ""
echo -e "${BOLD}═══════════════════════════════════════════════════════════════${NC}"
echo ""

# Require explicit confirmation
read -p "Type 'YES' (uppercase) to confirm: " confirm

if [ "$confirm" != "YES" ]; then
    echo ""
    echo "Cancelled."
    exit 0
fi

echo ""
echo -e "${CYAN}Creating ClusterOS USB installer...${NC}"
echo ""

# Unmount any existing partitions on target
echo "[1/3] Unmounting existing partitions..."
for part in "${TARGET_DEV}"*; do
    if [ -b "$part" ] && [ "$part" != "$TARGET_DEV" ]; then
        umount "$part" 2>/dev/null || true
    fi
done

# Write the image
echo "[2/5] Writing installer image (this may take several minutes)..."
gunzip -c "$INSTALLER_IMAGE" | dd of="$TARGET_DEV" bs=4M status=progress oflag=sync
sync

echo "[3/5] Fixing GPT backup header..."
if command -v sgdisk &>/dev/null; then
    sgdisk -e "$TARGET_DEV" 2>/dev/null || true
fi
partprobe "$TARGET_DEV" 2>/dev/null || true
sleep 2

echo "[4/5] Fixing UEFI boot (replacing systemd-boot with GRUB fallback)..."
EFI_PART=""
for candidate in "${TARGET_DEV}p15" "${TARGET_DEV}15" "${TARGET_DEV}p2" "${TARGET_DEV}2" \
                 "${TARGET_DEV}p1" "${TARGET_DEV}1"; do
    if [ -b "$candidate" ] && blkid "$candidate" 2>/dev/null | grep -qi "vfat\|fat32"; then
        EFI_PART="$candidate"; break
    fi
done

if [ -n "$EFI_PART" ]; then
    EFI_MNT="$(mktemp -d /tmp/clusteros-efi-XXXXXX)"
    if mount "$EFI_PART" "$EFI_MNT" 2>/dev/null; then
        mkdir -p "$EFI_MNT/EFI/BOOT"
        if [ -f "$EFI_MNT/EFI/ubuntu/shimx64.efi" ]; then
            cp "$EFI_MNT/EFI/ubuntu/shimx64.efi" "$EFI_MNT/EFI/BOOT/BOOTX64.EFI"
            echo "  Secure Boot shim -> BOOTX64.EFI"
        elif [ -f "$EFI_MNT/EFI/ubuntu/grubx64.efi" ]; then
            cp "$EFI_MNT/EFI/ubuntu/grubx64.efi" "$EFI_MNT/EFI/BOOT/BOOTX64.EFI"
            echo "  GRUB -> BOOTX64.EFI"
        fi
        cat > "$EFI_MNT/EFI/BOOT/grub.cfg" << 'GCFG'
set timeout=5
set default=0
search --no-floppy --label --set=root cloudimg-rootfs
if [ -z "${root}" ]; then search --no-floppy --label --set=root BOOT; fi
set prefix=(${root})/boot/grub
configfile ${prefix}/grub.cfg
menuentry "ClusterOS" {
    search --no-floppy --label --set=root cloudimg-rootfs
    linux /boot/vmlinuz root=LABEL=cloudimg-rootfs ro quiet
    initrd /boot/initrd.img
}
GCFG
        echo "  Fallback grub.cfg written"
        umount "$EFI_MNT"
    fi
    rmdir "$EFI_MNT" 2>/dev/null || true
else
    echo "  No EFI partition found — BIOS/legacy boot only"
fi

echo "[5/5] Syncing..."
sync

echo ""
echo -e "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
echo -e "${GREEN}           ✓ ClusterOS USB Installer Created!${NC}"
echo -e "${GREEN}═══════════════════════════════════════════════════════════════${NC}"
echo ""
echo "  USB Drive: $TARGET_DEV"
echo ""
echo -e "${YELLOW}To use this installer:${NC}"
echo "  1. Insert the USB into the target machine"
echo "  2. Boot from USB (may need to change BIOS boot order)"
echo "  3. Run ${GREEN}cluster-os-install${NC} to install to internal disk"
echo ""
echo "  The USB is also a fully functional ClusterOS system!"
echo ""
