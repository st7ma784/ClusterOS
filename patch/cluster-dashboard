#!/bin/bash
# ClusterOS - Real-Time Cluster Dashboard
# Usage: cluster-dashboard [--once] [--interval N]
#
# Displays a live-updating overview of the cluster:
#   - This node's info and IPs
#   - Tailscale peers
#   - Cluster members (from node-agent status)
#   - SLURM jobs
#   - K3s pods/workloads
#   - K3s service endpoints (IP:port)
#   - System resources

set -uo pipefail

GREEN='\033[0;32m'
RED='\033[0;31m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

INTERVAL=5
ONCE=false

# Parse arguments
while [ $# -gt 0 ]; do
    case "$1" in
        --once)    ONCE=true; shift ;;
        --interval) INTERVAL="$2"; shift 2 ;;
        -h|--help)
            echo "Usage: cluster-dashboard [--once] [--interval N]"
            echo ""
            echo "Options:"
            echo "  --once         Print one snapshot and exit"
            echo "  --interval N   Refresh every N seconds (default: 5)"
            echo "  -h, --help     Show this help"
            exit 0
            ;;
        *) echo "Unknown option: $1"; exit 1 ;;
    esac
done

STATUS_FILE="/run/clusteros/status.json"

render() {
    local cols
    cols=$(tput cols 2>/dev/null || echo 80)
    local line
    line=$(printf '─%.0s' $(seq 1 "$cols"))

    # Header
    echo -e "${CYAN}${BOLD}"
    echo "  ClusterOS Dashboard"
    echo -e "${NC}${DIM}  $(date '+%Y-%m-%d %H:%M:%S')   (refresh: ${INTERVAL}s — press Ctrl-C to exit)${NC}"
    echo -e "${CYAN}${line}${NC}"

    # ── This Node ──
    echo -e "\n${YELLOW}${BOLD} This Node${NC}"
    local hostname_val ip_val ts_ip uptime_val
    hostname_val=$(hostname 2>/dev/null || echo "unknown")
    ip_val=$(hostname -I 2>/dev/null | awk '{print $1}' || echo "N/A")
    ts_ip=$(tailscale ip -4 2>/dev/null || echo "N/A")
    uptime_val=$(uptime -p 2>/dev/null || uptime | sed 's/.*up /up /' | sed 's/,.*//')
    echo -e "  Hostname:     ${GREEN}$hostname_val${NC}"
    echo -e "  Local IP:     $ip_val"
    echo -e "  Tailscale IP: $ts_ip"
    echo -e "  Uptime:       $uptime_val"

    # ── Tailscale Peers ──
    echo -e "\n${YELLOW}${BOLD} Tailscale Peers${NC}"
    if command -v tailscale &>/dev/null && tailscale status &>/dev/null 2>&1; then
        local peer_count=0
        while IFS= read -r peer_line; do
            [ -z "$peer_line" ] && continue
            # Skip header line and self
            echo "$peer_line" | grep -q "^#\|offers" && continue
            local peer_ip peer_name peer_os peer_state
            peer_ip=$(echo "$peer_line" | awk '{print $1}')
            peer_name=$(echo "$peer_line" | awk '{print $2}')
            peer_state=$(echo "$peer_line" | awk '{print $5}')
            peer_os=$(echo "$peer_line" | awk '{print $3}')
            if [ "$peer_state" = "active;" ] || [ -n "$peer_ip" ]; then
                echo -e "  ${GREEN}●${NC} $peer_name  $peer_ip  $peer_os"
                ((peer_count++))
            fi
        done <<< "$(tailscale status 2>/dev/null | tail -n +2)"
        if [ "$peer_count" -eq 0 ]; then
            echo -e "  ${DIM}(no peers connected)${NC}"
        fi
    else
        echo -e "  ${DIM}(tailscale not available)${NC}"
    fi

    # ── Cluster Members ──
    echo -e "\n${YELLOW}${BOLD} Cluster Members${NC}"
    if [ -f "$STATUS_FILE" ] && command -v jq &>/dev/null; then
        local joined member_count leader election_mode
        joined=$(jq -r '.joined // false' "$STATUS_FILE" 2>/dev/null)
        member_count=$(jq -r '.member_count // 0' "$STATUS_FILE" 2>/dev/null)
        leader=$(jq -r '.leader // "none"' "$STATUS_FILE" 2>/dev/null)
        election_mode=$(jq -r '.election_mode // "unknown"' "$STATUS_FILE" 2>/dev/null)

        if [ "$joined" = "true" ] && [ "${member_count:-0}" -gt 0 ] 2>/dev/null; then
            echo -e "  Members: ${GREEN}$member_count${NC}  Leader: ${GREEN}$leader${NC}  Election: $election_mode"
            jq -r '.members[]? | "\(.status) \(.name) \(.addr)"' "$STATUS_FILE" 2>/dev/null | while read -r status name addr; do
                case "$status" in
                    alive)  echo -e "    ${GREEN}●${NC} $name  $addr" ;;
                    failed) echo -e "    ${RED}●${NC} $name  $addr  ${RED}failed${NC}" ;;
                    *)      echo -e "    ${YELLOW}●${NC} $name  $addr  $status" ;;
                esac
            done
        else
            echo -e "  ${DIM}(not joined to cluster)${NC}"
        fi
    else
        echo -e "  ${DIM}(status file not available)${NC}"
    fi

    # ── SLURM Jobs ──
    echo -e "\n${YELLOW}${BOLD} SLURM Jobs${NC}"
    if pgrep -x slurmctld &>/dev/null || pgrep -x slurmd &>/dev/null; then
        if command -v squeue &>/dev/null && squeue &>/dev/null 2>&1; then
            local job_output
            job_output=$(squeue --format="  %.8i %.12j %.8u %.2t %.10M %.6D %R" 2>/dev/null | head -11)
            if [ "$(echo "$job_output" | wc -l)" -le 1 ]; then
                echo -e "  ${DIM}(no jobs in queue)${NC}"
            else
                echo "$job_output"
            fi
            # Show node summary
            local node_info
            node_info=$(sinfo -h -o "  %P %a %D/%F" 2>/dev/null)
            [ -n "$node_info" ] && echo -e "\n  ${DIM}Partition  Avail  Nodes(A/I/O/T)${NC}" && echo "$node_info"
        else
            echo -e "  ${DIM}(squeue not reachable)${NC}"
        fi
    else
        echo -e "  ${DIM}(SLURM not running — waiting for node-agent)${NC}"
    fi

    # ── K3s Pods ──
    echo -e "\n${YELLOW}${BOLD} K3s Pods${NC}"
    if command -v k3s &>/dev/null && sudo k3s kubectl cluster-info &>/dev/null 2>&1; then
        local pod_output
        pod_output=$(sudo k3s kubectl get pods -A --no-headers 2>/dev/null | head -15)
        if [ -z "$pod_output" ]; then
            echo -e "  ${DIM}(no pods)${NC}"
        else
            echo "$pod_output" | while IFS= read -r pod_line; do
                local ns name ready status
                ns=$(echo "$pod_line" | awk '{print $1}')
                name=$(echo "$pod_line" | awk '{print $2}')
                ready=$(echo "$pod_line" | awk '{print $3}')
                status=$(echo "$pod_line" | awk '{print $4}')
                case "$status" in
                    Running)   echo -e "  ${GREEN}●${NC} $ns/$name  $ready  $status" ;;
                    Completed|Succeeded) echo -e "  ${GREEN}●${NC} $ns/$name  $ready  $status" ;;
                    Pending)   echo -e "  ${YELLOW}●${NC} $ns/$name  $ready  $status" ;;
                    *)         echo -e "  ${RED}●${NC} $ns/$name  $ready  $status" ;;
                esac
            done
        fi

        # ── K3s Workloads ──
        echo -e "\n${YELLOW}${BOLD} K3s Workloads${NC}"
        local workload_output
        workload_output=$(sudo k3s kubectl get deploy,statefulset -A --no-headers 2>/dev/null | head -20)
        if [ -z "$workload_output" ]; then
            echo -e "  ${DIM}(no deployments/statefulsets)${NC}"
        else
            echo "$workload_output" | while IFS= read -r wl_line; do
                local ns type name ready
                ns=$(echo "$wl_line" | awk '{print $1}')
                type=$(echo "$wl_line" | awk '{print $2}')
                name=$(echo "$wl_line" | awk '{print $3}')
                ready=$(echo "$wl_line" | awk '{print $4}')
                if [ -z "$ready" ]; then
                    echo -e "  ${DIM}$wl_line${NC}"
                    continue
                fi
                if echo "$ready" | awk -F'/' '{exit !($1==$2)}'; then
                    echo -e "  ${GREEN}●${NC} $ns/$name  ($type)  ready=$ready"
                else
                    echo -e "  ${YELLOW}●${NC} $ns/$name  ($type)  ready=$ready"
                fi
            done
        fi

        # ── K3s Service Endpoints ──
        echo -e "\n${YELLOW}${BOLD} K3s Service Endpoints${NC}"
        local preferred_ip svc_lines
        preferred_ip=$(tailscale ip -4 2>/dev/null | head -1)
        [ -z "$preferred_ip" ] && preferred_ip=$(hostname -I 2>/dev/null | awk '{print $1}')

        svc_lines=$(sudo k3s kubectl get svc -A --no-headers 2>/dev/null | \
            awk '$1=="cattle-system" && $2~/(rancher|rancher-nodeport)/ {print $1, $2}
                 $1=="longhorn-system" && $2~/(longhorn-frontend|longhorn-ui)/ {print $1, $2}
                 $1=="slurm" && $2~/(slurmdbd|slurmdbd-nodeport)/ {print $1, $2}
                 $1=="jupyterhub" && $2~/(proxy-public|hub|jupyterhub)/ {print $1, $2}
                 $1=="galaxy" {print $1, $2}' | head -20)

        if [ -z "$svc_lines" ]; then
            echo -e "  ${DIM}(no known service endpoints found yet)${NC}"
            echo -e "  ${DIM}Known services: rancher, longhorn, slurmdbd, jupyterhub, galaxy${NC}"
        else
            while read -r ns svc; do
                [ -z "$ns" ] && continue
                local type ports nodeports cluster_ip
                type=$(sudo k3s kubectl -n "$ns" get svc "$svc" -o jsonpath='{.spec.type}' 2>/dev/null)
                ports=$(sudo k3s kubectl -n "$ns" get svc "$svc" -o jsonpath='{range .spec.ports[*]}{.port}{"/"}{.protocol}{" "}{end}' 2>/dev/null)
                nodeports=$(sudo k3s kubectl -n "$ns" get svc "$svc" -o jsonpath='{range .spec.ports[*]}{.nodePort}{" "}{end}' 2>/dev/null)
                cluster_ip=$(sudo k3s kubectl -n "$ns" get svc "$svc" -o jsonpath='{.spec.clusterIP}' 2>/dev/null)

                if [ "$type" = "NodePort" ] && [ -n "$nodeports" ] && [ -n "$preferred_ip" ]; then
                    local endpoints
                    endpoints=$(echo "$nodeports" | awk -v ip="$preferred_ip" '{for(i=1;i<=NF;i++) if($i!="") printf "https://%s:%s ", ip, $i}')
                    echo -e "  ${GREEN}●${NC} $ns/$svc  [$type]  ports: ${ports:-N/A}"
                    echo -e "     ${CYAN}→${NC} ${endpoints}"
                else
                    echo -e "  ${GREEN}●${NC} $ns/$svc  [$type]  ports: ${ports:-N/A}  clusterIP=${cluster_ip:-N/A}"
                fi
            done <<< "$svc_lines"
        fi
    else
        echo -e "  ${DIM}(K3s not available)${NC}"
    fi

    # ── System Resources ──
    echo -e "\n${YELLOW}${BOLD} System Resources${NC}"
    # Load average
    local load
    load=$(awk '{printf "%.2f %.2f %.2f", $1, $2, $3}' /proc/loadavg 2>/dev/null || echo "N/A")
    local cpus
    cpus=$(nproc 2>/dev/null || echo "?")
    echo -e "  Load:    $load  (${cpus} CPUs)"

    # Memory
    local mem_total mem_used mem_pct
    mem_total=$(free -h 2>/dev/null | awk '/^Mem:/{print $2}')
    mem_used=$(free -h 2>/dev/null | awk '/^Mem:/{print $3}')
    mem_pct=$(free 2>/dev/null | awk '/^Mem:/{printf "%.0f", $3/$2*100}')
    if [ -n "$mem_total" ]; then
        local mem_color="$GREEN"
        [ "${mem_pct:-0}" -gt 80 ] && mem_color="$YELLOW"
        [ "${mem_pct:-0}" -gt 95 ] && mem_color="$RED"
        echo -e "  Memory:  ${mem_color}${mem_used}${NC} / ${mem_total} (${mem_pct}%)"
    fi

    # Disk
    local disk_info
    disk_info=$(df -h / 2>/dev/null | awk 'NR==2{printf "%s / %s (%s)", $3, $2, $5}')
    if [ -n "$disk_info" ]; then
        local disk_pct
        disk_pct=$(df / 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
        local disk_color="$GREEN"
        [ "${disk_pct:-0}" -gt 80 ] && disk_color="$YELLOW"
        [ "${disk_pct:-0}" -gt 95 ] && disk_color="$RED"
        echo -e "  Disk:    ${disk_color}${disk_info}${NC}"
    fi

    echo ""
}

# Main loop
if [ "$ONCE" = true ]; then
    render
else
    # Trap Ctrl-C for clean exit
    trap 'tput cnorm 2>/dev/null; echo -e "\n${NC}Dashboard stopped."; exit 0' INT TERM
    tput civis 2>/dev/null  # Hide cursor
    while true; do
        tput clear 2>/dev/null || clear
        render
        sleep "$INTERVAL"
    done
fi
